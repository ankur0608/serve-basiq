generator client {
    provider   = "prisma-client-js"
    engineType = "library"
}

datasource db {
    provider = "postgresql"
}

enum PriceType {
    HOURLY
    FIXED
    QUOTE
}

enum BookingStatus {
    REQUESTED
    ACCEPTED
    IN_PROGRESS
    COMPLETED
    CANCELLED
}

enum RequestType {
    PRODUCT
    SERVICE
}

enum RequestStatus {
    OPEN
    IN_PROGRESS
    CLOSED
}

enum OrderStatus {
    REQUESTED
    ACCEPTED
    SHIPPED
    DELIVERED
    CANCELLED
}

enum PaymentStatus {
    PENDING
    PAID
    FAILED
    REFUNDED
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum PropertyType {
    FLAT
    VILLA
    OFFICE
    OTHER
}

enum PaymentMode {
    ONLINE
    CASH
}

enum StockStatus {
    IN_STOCK
    OUT_OF_STOCK
    ON_DEMAND
    MADE_TO_ORDER
}

enum UnitType {
    PIECE
    KG
    GRAM
    LITER
    ML
    BOX
    PACK
    SET
    METER
    SQ_FT
    TON
}

enum Condition {
    NEW
    USED
    REFURBISHED
}

enum DeliveryType {
    PICKUP
    DELIVERY
    BOTH
}

enum PayoutMethod {
    BANK
    UPI
}

enum Timeline {
    URGENT
    IMMEDIATE
    LATER
    FLEXIBLE
}

enum CategoryType {
    SERVICE
    PRODUCT
    BOTH
    RENTAL
}

enum RentalStatus {
    REQUESTED
    ACCEPTED
    IN_PROGRESS
    COMPLETED
    CANCELLED
}

enum RentalPricingModel {
    DAILY
    MONTHLY
    FIXED
}

enum RentalMode {
    PICKUP
    DELIVERY
    BOTH
}

enum RentalCondition {
    NEW
    EXCELLENT
    GOOD
    USED
}

enum MinRentalDuration {
    ONE_HOUR
    ONE_DAY
    SEVEN_DAYS
    FIFTEEN_DAYS
    THIRTY_DAYS
}

enum RentalPricingType {
    HOURLY
    DAILY
    WEEKLY
    MONTHLY
    QUOTE
    FIXED
}

model RentalBooking {
    id String @id @default(cuid())

    userId String
    user   User   @relation("RenterUser", fields: [userId], references: [id])

    rentalId String
    rental   Rental @relation(fields: [rentalId], references: [id])

    addressId String?
    address   Address? @relation(fields: [addressId], references: [id])

    slotId String?      @unique
    slot   RentalSlot?  @relation(fields: [slotId], references: [id])

    startDate DateTime
    endDate   DateTime
    totalDays Int      @default(1)

    minDuration MinRentalDuration @default(ONE_DAY)

    pricingModel       RentalPricingType @default(DAILY)
    dailyRentalPrice   Float?
    monthlyRentalPrice Float?
    fixedRentalPrice   Float?

    totalPrice Float

    status        RentalStatus  @default(REQUESTED)
    paymentStatus PaymentStatus @default(PENDING)
    deliveryType  DeliveryType  @default(PICKUP)

    specialInstructions String?
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt
}

model RentalSlot {
    id       String @id @default(cuid())
    rentalId String
    rental   Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

    date      DateTime
    startTime String
    endTime   String

    isActive Boolean @default(true)
    isBooked Boolean @default(false)

    booking RentalBooking?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([rentalId, date])
    @@index([rentalId, isActive, isBooked])
}

model Rental {
    id     String @id @default(uuid())
    userId String
    user   User   @relation(fields: [userId], references: [id])

    name           String
    desc           String
    rentalImg      String
    coverImg       String?
    gallery        String[]
    rentalImages   String[]
    categoryId     String?
    category       Category? @relation("RentalMainCategory", fields: [categoryId], references: [id])
    customCategory String?
    subCategoryId  String?
    subcategory    Category? @relation("RentalSubCategory", fields: [subCategoryId], references: [id])

    price Float @default(0)

    priceType RentalPricingType @default(DAILY)

    stock Int @default(1)

    hourlyPrice  Float?
    dailyPrice   Float?
    weeklyPrice  Float?
    monthlyPrice Float?
    fixedPrice   Float?

    itemCondition RentalCondition @default(GOOD)

    securityDeposit Float?  @default(0)
    minDuration     String?
    maxDuration     String?

    rentalMode RentalMode @default(PICKUP)

    addressLine1 String?
    addressLine2 String?
    city         String?
    state        String?
    pincode      String?
    latitude     Decimal?
    longitude    Decimal?
    radiusKm     Int?     @default(10)

    isVerified  Boolean  @default(false)
    isAvailable Boolean  @default(true)
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    bookings       Booking[]
    favoritedBy    FavoriteRental[]
    rentalBookings RentalBooking[]
    reviews        Review[]
    slots          RentalSlot[]

    @@index([userId])
    @@index([categoryId])
    @@index([subCategoryId])
    @@index([city])
    @@index([pincode])
    @@index([latitude, longitude])
    @@index([isVerified, itemCondition, priceType])
    @@index([isVerified, categoryId])
    @@index([isVerified, createdAt(sort: Desc)])
    @@index([userId, createdAt(sort: Desc)])
}

model Category {
    id    String        @id @default(uuid())
    name  String        @unique
    type  CategoryType?
    image String?

    parentId String?
    parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
    children Category[] @relation("CategoryHierarchy")

    services      Service[] @relation("MainCategory")
    servicesInSub Service[] @relation("ServiceSubCategory")

    products      Product[] @relation("ProductMainCategory")
    productsInSub Product[] @relation("ProductSubCategory")

    rentals      Rental[] @relation("RentalMainCategory")
    rentalsInSub Rental[] @relation("RentalSubCategory")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    service   Service? @relation(fields: [serviceId], references: [id])
    serviceId String?
    product   Product? @relation(fields: [productId], references: [id])
    productId String?

    @@index([parentId])
    @@index([type])
}

model Admin {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String
    isOnline  Boolean  @default(false)
    lastLogin DateTime @default(now())
    createdAt DateTime @default(now())
}

model Booking {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    serviceId String
    service   Service @relation(fields: [serviceId], references: [id])

    addressId String
    address   Address @relation(fields: [addressId], references: [id])

    timeline Timeline @default(IMMEDIATE)

    specialInstructions String?

    status    BookingStatus @default(REQUESTED)
    rentalId  String?
    rental    Rental?       @relation(fields: [rentalId], references: [id])
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
}

model Order {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    productId String
    product   Product @relation(fields: [productId], references: [id])

    addressId String?
    address   Address? @relation(fields: [addressId], references: [id])

    quantity   Int
    unit       UnitType
    totalPrice Float

    status        OrderStatus   @default(REQUESTED)
    timeline      Timeline      @default(IMMEDIATE)
    paymentStatus PaymentStatus @default(PENDING)

    specialInstructions String?
    trackingId          String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model User {
    id            String    @id @default(cuid())
    name          String?
    shopName      String?
    phone         String?   @unique
    email         String?   @unique
    emailVerified DateTime?
    image         String?

    role              String        @default("USER")
    profileImage      String?
    gender            Gender?
    dob               DateTime?
    preferredLanguage String?       @default("English")

    isPhoneVerified Boolean  @default(false)
    isWorker        Boolean  @default(false)
    isWebsite       Boolean  @default(true)
    rejectionReason String?
    rentals         Rental[]

    isOnline       Boolean @default(false)
    isAdminCreated Boolean @default(false)
    instagramUrl   String?
    facebookUrl    String?
    websiteUrl     String?
    youtubeUrl     String?
    isVerified     Boolean @default(false)

    bankAccountHolder     String?
    bankAccountNumber     String?
    bankIfsc              String?
    bankName              String?
    upiId                 String?
    preferredPayoutMethod PayoutMethod? @default(BANK)

    kycDetails   KycDetails?
    accounts     Account[]
    services     Service[]
    addresses    Address[]
    products     Product[]
    reviews      Review[]
    bookings     Booking[]
    requirements Requirement[]

    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    orders           Order[]
    favoriteServices FavoriteService[]
    favoriteProducts FavoriteProduct[]
    rentalBookings   RentalBooking[]   @relation("RenterUser")
    favoriteRentals  FavoriteRental[]
    contactMessages  ContactMessage[]
    workers          Worker[]          @relation("ProviderWorkers")
}

model KycDetails {
    id String @id @default(cuid())

    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    idProofType   String? @default("Aadhaar")
    idProofNumber String?

    idProofFrontImg  String?
    idProofBackImg   String?
    businessProofImg String?

    gstRegistered Boolean @default(false)
    gstNumber     String?

    status       String  @default("PENDING")
    rejectionMsg String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Address {
    id             String          @id @default(cuid())
    userId         String
    user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    landmark       String?
    type           String          @default("Home")
    line1          String
    line2          String
    city           String
    district       String?
    state          String
    pincode        String
    country        String          @default("India")
    requirements   Requirement[]
    createdAt      DateTime        @default(now())
    bookings       Booking[]
    orders         Order[]
    rentalBookings RentalBooking[]
}

model Requirement {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    type        RequestType
    title       String
    description String

    status RequestStatus @default(OPEN)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    address   Address? @relation(fields: [addressId], references: [id])
    addressId String?
    timeline  Timeline @default(IMMEDIATE)
}

model Otp {
    id        String    @id @default(cuid())
    phone     String    @unique
    code      String?
    expiresAt DateTime?
    attempts  Int       @default(0)
    lockUntil DateTime?
    createdAt DateTime  @default(now())
    updatedAt DateTime  @default(now()) @updatedAt
}

model OtpLog {
    id        String   @id @default(cuid())
    phone     String
    createdAt DateTime @default(now())

    @@index([phone])
}

model AdminActivityLog {
    id String @id @default(cuid())

    adminId    String
    adminEmail String

    action String

    entityType String?
    entityId   String?
    entityName String?

    details   String?
    ipAddress String?

    createdAt DateTime @default(now())

    @@index([adminId])
    @@index([action])
    @@index([createdAt])
}

model Service {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    name       String
    desc       String
    serviceimg String
    experience Int?
    altPhone   String?
    coverImg   String?
    mainimg    String?

    categoryId String?
    category   Category? @relation("MainCategory", fields: [categoryId], references: [id])

    subCategoryId  String?
    subcategory    Category? @relation("ServiceSubCategory", fields: [subCategoryId], references: [id])
    customCategory String?
    priceType      PriceType @default(FIXED)
    price          Float     @default(0)

    addressLine1 String?
    addressLine2 String?
    city         String?
    state        String?
    pincode      String?
    latitude     Decimal?
    longitude    Decimal?
    radiusKm     Int?     @default(10)
    loc          String?

    workingDays String[]
    openTime    String?
    closeTime   String?
    isRemote    Boolean  @default(false)
    is24x7      Boolean  @default(false)

    rating        Float    @default(5.0)
    isVerified    Boolean  @default(false)
    gallery       String[]
    serviceImages String[]
    reviews       Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    bookings    Booking[]
    favoritedBy FavoriteService[]
    categories  Category[]

    @@index([userId])
    @@index([categoryId])
    @@index([subCategoryId])
    @@index([city])
    @@index([pincode])
    @@index([latitude, longitude])
    @@index([isVerified, priceType])
    @@index([isVerified, categoryId])
    @@index([isVerified, createdAt(sort: Desc)])
    @@index([userId, createdAt(sort: Desc)])
}

model Review {
    id      Int      @id @default(autoincrement())
    rating  Int
    comment String?
    images  String[]

    userId String

    serviceId String?
    service   Service? @relation(fields: [serviceId], references: [id])

    productId String?
    product   Product? @relation(fields: [productId], references: [id])

    rentalId String?
    rental   Rental? @relation(fields: [rentalId], references: [id])

    authorId String
    author   User   @relation(fields: [authorId], references: [id])

    createdAt DateTime @default(now())

    @@index([serviceId, createdAt(sort: Desc)])
    @@index([productId, createdAt(sort: Desc)])
    @@index([rentalId, createdAt(sort: Desc)])
    @@index([authorId])
}

model Product {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    name String
    desc String

    categoryId     String?
    category       Category? @relation("ProductMainCategory", fields: [categoryId], references: [id])
    customCategory String?
    subCategoryId  String?
    subcategory    Category? @relation("ProductSubCategory", fields: [subCategoryId], references: [id])
    productImage   String?
    productImages  String[]
    gallery        String[]

    priceType PriceType @default(FIXED) // <-- Added PriceType field here
    price     Float
    moq       Int

    condition Condition @default(NEW)

    stockStatus  StockStatus  @default(IN_STOCK)
    unit         UnitType     @default(PIECE)
    deliveryType DeliveryType @default(DELIVERY)
    isVerified   Boolean      @default(false)
    createdAt    DateTime     @default(now())

    orders      Order[]
    favoritedBy FavoriteProduct[]
    categories  Category[]
    reviews     Review[]

    @@index([userId])
    @@index([categoryId])
    @@index([subCategoryId])
    @@index([isVerified, stockStatus, condition])
    @@index([createdAt])
    @@index([isVerified, categoryId])
    @@index([isVerified, createdAt(sort: Desc)])
    @@index([userId, createdAt(sort: Desc)])
}

model FavoriteService {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    serviceId String
    service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@unique([userId, serviceId])
}

model FavoriteProduct {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    productId String
    product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@unique([userId, productId])
}

model FavoriteRental {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    rentalId  String
    rental    Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@unique([userId, rentalId])
}

model ContactMessage {
    id String @id @default(cuid())

    // Link to user (optional so non-logged-in users can still contact you)
    userId String?
    user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    name     String
    email    String
    category String
    message  String @db.Text

    status    String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Worker {
    id String @id @default(cuid())

    name      String
    phone     String  @unique
    email     String?
    image     String?
    gender    Gender?
    roleType  String? // e.g., "Plumber", "Driver", "Assistant"
    
    // Link to the provider/shop owner
    providerId String
    provider   User   @relation("ProviderWorkers", fields: [providerId], references: [id])

    isVerified Boolean @default(true)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
}
