generator client {
    provider        = "prisma-client-js"
    engineType      = "library"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider = "postgresql"
}

model Admin {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String // Will be hashed
    isOnline  Boolean  @default(false)
    lastLogin DateTime @default(now())
    createdAt DateTime @default(now())
}

model User {
    id   String  @id @default(cuid())
    name String?

    // ⚠️ CHANGE: Phone must be optional for Google Auth (users might not have one yet)
    phone String? @unique

    email         String?   @unique
    emailVerified DateTime? // ✅ Added: Standard NextAuth field
    image         String? // ✅ Added: Standard NextAuth profile image field

    role String  @default("USER")
    img  String? // Your existing custom image field (keep this if your UI uses it)

    isPhoneVerified Boolean @default(false)
    isWorker        Boolean @default(false)
    isWebsite       Boolean @default(true)

    // ✅ STATUS FLAGS
    isVerified         Boolean @default(false)
    verificationStatus String  @default("PENDING")

    // ✅ BANKING DETAILS
    bankAccountHolder String?
    bankAccountNumber String?
    bankIfsc          String?
    bankName          String?
    upiId             String?

    // ✅ KYC DOCUMENTS
    idProofType      String? @default("Aadhaar")
    idProofNumber    String?
    idProofImg       String?
    businessProofImg String?

    // ✅ RELATION: Link to the Account model for Google/NextAuth
    accounts Account[]

    // Relations
    services  Service[]
    addresses Address[]
    products  Product[]
    reviews   Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// ✅ NEW: Account Model (Required for NextAuth/Google)
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

