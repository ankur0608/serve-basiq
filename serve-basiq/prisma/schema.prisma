generator client {
    provider        = "prisma-client-js"
    engineType      = "library"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider = "postgresql"
}

enum PriceType {
    HOURLY
    FIXED
}

enum BookingStatus {
    PENDING
    CONFIRMED
    COMPLETED
    CANCELLED
}

enum RequestType {
    PRODUCT
    SERVICE
}

enum RequestStatus {
    OPEN
    IN_PROGRESS
    CLOSED
}

enum OrderStatus {
    PENDING
    CONFIRMED
    SHIPPED
    OUT_FOR_DELIVERY
    DELIVERED
    CANCELLED
    RETURNED
}

enum PaymentStatus {
    PENDING
    PAID
    FAILED
    REFUNDED
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum PropertyType {
    FLAT
    VILLA
    OFFICE
    OTHER
}

enum PaymentMode {
    ONLINE
    CASH
}

enum StockStatus {
    IN_STOCK
    ON_DEMAND
}

enum UnitType {
    PIECE
    KG
    BOX
    LITER
}

enum DeliveryType {
    PICKUP
    DELIVERY
}

enum PayoutMethod {
    BANK
    UPI
}

enum Timeline {
    IMMEDIATE
    IN_2_DAYS
    TWO_TO_FIVE_DAYS
}

model Admin {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String // Will be hashed
    isOnline  Boolean  @default(false)
    lastLogin DateTime @default(now())
    createdAt DateTime @default(now())
}

model Booking {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    serviceId String
    service   Service @relation(fields: [serviceId], references: [id])

    addressId String
    address   Address @relation(fields: [addressId], references: [id])

    timeline Timeline @default(IMMEDIATE)

    specialInstructions String?

    status BookingStatus @default(PENDING)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Order {
    id String @id @default(cuid())

    // --- 1. RELATIONS ---
    userId String
    user   User   @relation(fields: [userId], references: [id])

    productId String
    product   Product @relation(fields: [productId], references: [id])

    // Address is optional because DeliveryType could be 'PICKUP'
    addressId String?
    address   Address? @relation(fields: [addressId], references: [id])

    // --- 2. ORDER DETAILS ---
    quantity   Int
    unit       UnitType // Uses your existing UnitType enum
    totalPrice Float // Price * Quantity (calculated at creation)

    deliveryType DeliveryType // Uses your existing DeliveryType enum

    // --- 3. STATUS & PAYMENT ---
    status OrderStatus @default(PENDING) // ✅ Uses new Enum

    paymentMode PaymentMode @default(CASH) // ✅ Uses existing Enum

    paymentStatus PaymentStatus @default(PENDING) // ✅ Uses new Enum

    // --- 4. EXTRAS ---
    specialInstructions String?
    trackingId          String? // For courier tracking number

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model User {
    id            String    @id @default(cuid())
    name          String?
    shopName      String?
    phone         String?   @unique
    email         String?   @unique
    emailVerified DateTime?
    image         String?

    role         String  @default("USER")
    profileImage String?

    gender            Gender?
    dob               DateTime?
    preferredLanguage String?   @default("English")

    isPhoneVerified Boolean @default(false)
    isWorker        Boolean @default(false)
    isWebsite       Boolean @default(true)
    rejectionReason String?

    // ✅ UPDATED: Kept the fast status flag here, but details are moved
    isVerified Boolean @default(false)

    // Banking (Can stay here or move to its own model too, but fine here for now)
    bankAccountHolder     String?
    bankAccountNumber     String?
    bankIfsc              String?
    bankName              String?
    upiId                 String?
    preferredPayoutMethod PayoutMethod? @default(BANK)

    // ✅ NEW: Relation to KYC Model
    kycDetails KycDetails?

    accounts     Account[]
    services     Service[]
    addresses    Address[]
    products     Product[]
    reviews      Review[]
    bookings     Booking[]
    requirements Requirement[] // Add this relation

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    orders    Order[]
}

model KycDetails {
    id String @id @default(cuid())

    // 1:1 Relation with User
    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    // Document Details
    idProofType   String? @default("Aadhaar")
    idProofNumber String?

    // Images
    idProofFrontImg  String?
    idProofBackImg   String?
    businessProofImg String?

    // Tax Info
    gstRegistered Boolean @default(false)
    gstNumber     String?

    // Status for the KYC specifically
    status       String  @default("PENDING") // PENDING, APPROVED, REJECTED
    rejectionMsg String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

// --- ADDRESS MODEL (NEW) ---
model Address {
    id           String        @id @default(cuid())
    userId       String
    user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
    landmark     String? // ✅ NEW: Added Landmark
    type         String        @default("Home") // Home, Work, Other
    line1        String // Flat, Building, Street
    line2        String
    city         String
    state        String
    pincode      String
    country      String        @default("India")
    requirements Requirement[] // Add this relation

    createdAt DateTime  @default(now())
    bookings  Booking[]
    orders    Order[]
}

model Requirement {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    type        RequestType // PRODUCT or SERVICE
    title       String // Requirement Title
    description String // Detailed description

    // Location
    addressId String
    address   Address @relation(fields: [addressId], references: [id])

    status RequestStatus @default(OPEN)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// --- OTP MODEL ---
model Otp {
    id        String   @id @default(cuid())
    phone     String
    code      String
    expiresAt DateTime
    createdAt DateTime @default(now())
}

model Service {
    id String @id @default(uuid())

    userId     String
    user       User      @relation(fields: [userId], references: [id])
    name       String
    desc       String
    serviceimg String
    experience Int?
    altPhone   String?
    coverImg   String?
    mainimg    String?
    category   Category? @relation(fields: [categoryId], references: [id])
    categoryId String?

    subCategoryIds String[]
    priceType      PriceType @default(FIXED)
    price          Float     @default(0)

    addressLine1 String?
    addressLine2 String?
    city         String?
    state        String?
    pincode      String?

    latitude  Decimal?
    longitude Decimal?
    radiusKm  Int?     @default(10)

    workingDays String[]
    openTime    String?
    closeTime   String?

    instagramUrl String?
    facebookUrl  String?
    websiteUrl   String?
    youtubeUrl   String?

    // Details
    rating     Float    @default(5.0)
    loc        String?
    isVerified Boolean  @default(false)
    gallery    String[]

    reviews Review[]

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    bookings  Booking[]
}

model Category {
    id       String    @id @default(uuid())
    name     String
    services Service[]
}

model Review {
    id      Int     @id @default(autoincrement())
    rating  Int
    comment String?

    serviceId String
    service   Service @relation(fields: [serviceId], references: [id])

    authorId String
    author   User   @relation(fields: [authorId], references: [id])

    createdAt DateTime @default(now())
}

model Product {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    name     String
    category String
    desc     String

    productImage String
    gallery      String[]

    price Float
    moq   Int

    stockStatus  StockStatus  @default(IN_STOCK)
    unit         UnitType     @default(PIECE)
    deliveryType DeliveryType @default(DELIVERY)

    isVerified Boolean  @default(false)
    createdAt  DateTime @default(now())
    orders     Order[]
}
