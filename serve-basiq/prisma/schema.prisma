generator client {
    provider        = "prisma-client-js"
    engineType      = "library"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider = "postgresql"
}

enum PriceType {
    HOURLY
    FIXED
}

enum BookingStatus {
    REQUESTED
    ACCEPTED
    IN_PROGRESS
    COMPLETED
    CANCELLED
}

enum RequestType {
    PRODUCT
    SERVICE
}

enum RequestStatus {
    OPEN
    IN_PROGRESS
    CLOSED
}

enum OrderStatus {
    REQUESTED
    ACCEPTED
    SHIPPED
    DELIVERED
    CANCELLED
}

enum PaymentStatus {
    PENDING
    PAID
    FAILED
    REFUNDED
}

enum Gender {
    MALE
    FEMALE
    OTHER
}

enum PropertyType {
    FLAT
    VILLA
    OFFICE
    OTHER
}

enum PaymentMode {
    ONLINE
    CASH
}

enum StockStatus {
    IN_STOCK
    ON_DEMAND
}

enum UnitType {
    PIECE
    KG
    BOX
    LITER
}

enum DeliveryType {
    PICKUP
    DELIVERY
}

enum PayoutMethod {
    BANK
    UPI
}

enum Timeline {
    IMMEDIATE
    IN_2_DAYS
    TWO_TO_FIVE_DAYS
}

enum CategoryType {
    SERVICE
    PRODUCT
    BOTH
    RENTAL
}

enum RentalStatus {
    REQUESTED // Customer sent request
    APPROVED // Owner accepted
    ACTIVE // Customer has the item (Picked up)
    COMPLETED // Customer returned the item
    CANCELLED // Request cancelled
    OVERDUE // Date passed but not returned
}

// 2. Create the new RentalBooking model
model RentalBooking {
    id String @id @default(cuid())

    // Relationships
    userId String
    user   User   @relation("RenterUser", fields: [userId], references: [id])

    rentalId String
    rental   Rental @relation(fields: [rentalId], references: [id])

    addressId String?
    address   Address? @relation(fields: [addressId], references: [id])

    // Booking Details
    startDate DateTime
    endDate   DateTime
    totalDays Int      @default(1)

    // Cost Calculation
    pricePerDay Float
    totalPrice  Float

    // Statuses
    status        RentalStatus  @default(REQUESTED)
    paymentStatus PaymentStatus @default(PENDING)
    deliveryType  DeliveryType  @default(PICKUP)

    // Meta
    specialInstructions String?
    createdAt           DateTime @default(now())
    updatedAt           DateTime @updatedAt

    // REMOVED THE DUPLICATE 'user' LINE THAT WAS HERE
}

model Rental {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    // --- Basic Info ---
    name      String
    desc      String
    rentalImg String
    coverImg  String?
    gallery   String[]

    // --- Category (Matches "Rental Category" dropdown) ---
    categoryId String?
    category   Category? @relation("RentalMainCategory", fields: [categoryId], references: [id])

    subCategoryId String?
    subcategory   Category? @relation("RentalSubCategory", fields: [subCategoryId], references: [id])

    // --- Pricing & Stock ---
    price     Float  @default(0)
    priceType String
    stock     Int    @default(1)

    // ✅ NEW FIELDS FROM IMAGE -------------------------

    // "Item Condition" (e.g., New, Used, Good)
    itemCondition String? @default("Good")

    // "Security Deposit (₹)"
    securityDeposit Float? @default(0)

    // "Min Rental Duration" (e.g., "1 Hour")
    minDuration String?

    // "Max Rental Duration" (e.g., "7 Days")
    maxDuration String?

    // "Rental Mode" (e.g., Pickup, Home Delivery, Both)
    rentalMode String? @default("PICKUP")

    // --------------------------------------------------

    // --- Location ---
    addressLine1 String?
    addressLine2 String?
    city         String?
    state        String?
    pincode      String?
    latitude     Decimal?
    longitude    Decimal?
    radiusKm     Int?     @default(10)

    // --- System ---
    isVerified     Boolean         @default(false)
    createdAt      DateTime        @default(now())
    updatedAt      DateTime        @updatedAt
    bookings       Booking[]
    rentalBookings RentalBooking[]
}

model Category {
    id    String        @id @default(uuid())
    name  String        @unique
    type  CategoryType?
    image String?

    // 1. Hierarchy (Parent/Child)
    parentId String?
    parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
    children Category[] @relation("CategoryHierarchy")

    // 2. Services Relations
    services      Service[] @relation("MainCategory")
    servicesInSub Service[] @relation("ServiceSubCategory")

    // 3. Products Relations
    products      Product[] @relation("ProductMainCategory")
    productsInSub Product[] @relation("ProductSubCategory")

    // 4. Rentals Relations
    rentals      Rental[] @relation("RentalMainCategory")
    rentalsInSub Rental[] @relation("RentalSubCategory")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    service   Service? @relation(fields: [serviceId], references: [id])
    serviceId String?
    product   Product? @relation(fields: [productId], references: [id])
    productId String?
}

model Admin {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String
    isOnline  Boolean  @default(false)
    lastLogin DateTime @default(now())
    createdAt DateTime @default(now())
}

model Booking {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    serviceId String
    service   Service @relation(fields: [serviceId], references: [id])

    addressId String
    address   Address @relation(fields: [addressId], references: [id])

    timeline Timeline @default(IMMEDIATE)

    specialInstructions String?

    status    BookingStatus @default(REQUESTED)
    rentalId  String?
    rental    Rental?       @relation(fields: [rentalId], references: [id])
    createdAt DateTime      @default(now())
    updatedAt DateTime      @updatedAt
}

model Order {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    productId String
    product   Product @relation(fields: [productId], references: [id])

    addressId String?
    address   Address? @relation(fields: [addressId], references: [id])

    quantity   Int
    unit       UnitType
    totalPrice Float

    status        OrderStatus   @default(REQUESTED)
    timeline      Timeline      @default(IMMEDIATE)
    paymentStatus PaymentStatus @default(PENDING)

    specialInstructions String?
    trackingId          String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model User {
    id            String    @id @default(cuid())
    name          String?
    shopName      String?
    phone         String?   @unique
    email         String?   @unique
    emailVerified DateTime?
    image         String?

    role              String        @default("USER")
    profileImage      String?
    providerType      CategoryType?
    gender            Gender?
    dob               DateTime?
    preferredLanguage String?       @default("English")

    isPhoneVerified Boolean  @default(false)
    isWorker        Boolean  @default(false)
    isWebsite       Boolean  @default(true)
    rejectionReason String?
    rentals         Rental[] // ✅ Add this

    instagramUrl String?
    facebookUrl  String?
    websiteUrl   String?
    youtubeUrl   String?
    isVerified   Boolean @default(false)

    bankAccountHolder     String?
    bankAccountNumber     String?
    bankIfsc              String?
    bankName              String?
    upiId                 String?
    preferredPayoutMethod PayoutMethod? @default(BANK)

    kycDetails KycDetails?

    accounts     Account[]
    services     Service[]
    addresses    Address[]
    products     Product[]
    reviews      Review[]
    bookings     Booking[]
    requirements Requirement[]

    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    orders           Order[]
    favoriteServices FavoriteService[]
    favoriteProducts FavoriteProduct[]
    rentalBookings   RentalBooking[]   @relation("RenterUser")
}

model KycDetails {
    id String @id @default(cuid())

    userId String @unique
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    idProofType   String? @default("Aadhaar")
    idProofNumber String?

    idProofFrontImg  String?
    idProofBackImg   String?
    businessProofImg String?

    gstRegistered Boolean @default(false)
    gstNumber     String?

    status       String  @default("PENDING")
    rejectionMsg String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

model Address {
    id             String          @id @default(cuid())
    userId         String
    user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
    landmark       String?
    type           String          @default("Home")
    line1          String
    line2          String
    city           String
    district       String?
    state          String
    pincode        String
    country        String          @default("India")
    requirements   Requirement[]
    createdAt      DateTime        @default(now())
    bookings       Booking[]
    orders         Order[]
    rentalBookings RentalBooking[]
}

model Requirement {
    id String @id @default(cuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    type        RequestType
    title       String
    description String

    status RequestStatus @default(OPEN)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    address   Address? @relation(fields: [addressId], references: [id])
    addressId String?
}

model Otp {
    id        String   @id @default(cuid())
    phone     String
    code      String
    expiresAt DateTime
    createdAt DateTime @default(now())
}

model Service {
    id String @id @default(uuid())

    userId     String
    user       User    @relation(fields: [userId], references: [id])
    name       String
    desc       String
    serviceimg String
    experience Int?
    altPhone   String?
    coverImg   String?
    mainimg    String?

    // ✅ 1. Main Category
    categoryId String?
    category   Category? @relation("MainCategory", fields: [categoryId], references: [id])

    // ✅ 2. Subcategory
    subCategoryId String?
    subcategory   Category? @relation("ServiceSubCategory", fields: [subCategoryId], references: [id])

    priceType PriceType @default(FIXED)
    price     Float     @default(0)

    addressLine1 String?
    addressLine2 String?
    city         String?
    state        String?
    pincode      String?

    latitude  Decimal?
    longitude Decimal?
    radiusKm  Int?     @default(10)

    workingDays String[]
    openTime    String?
    closeTime   String?

    rating     Float    @default(5.0)
    loc        String?
    isVerified Boolean  @default(false)
    gallery    String[]
    reviews    Review[]

    createdAt   DateTime          @default(now())
    updatedAt   DateTime          @updatedAt
    bookings    Booking[]
    favoritedBy FavoriteService[]
    categories  Category[]
}

model Review {
    id      Int      @id @default(autoincrement())
    rating  Int
    comment String?
    images  String[]

    serviceId String
    service   Service @relation(fields: [serviceId], references: [id])

    authorId String
    author   User   @relation(fields: [authorId], references: [id])

    createdAt DateTime @default(now())
}

model Product {
    id String @id @default(uuid())

    userId String
    user   User   @relation(fields: [userId], references: [id])

    name String
    desc String

    // ✅ 1. Main Category
    categoryId String?
    category   Category? @relation("ProductMainCategory", fields: [categoryId], references: [id])

    // ✅ 2. Subcategory
    subCategoryId String?
    subcategory   Category? @relation("ProductSubCategory", fields: [subCategoryId], references: [id])

    productImage String
    gallery      String[]
    price        Float
    moq          Int

    stockStatus  StockStatus       @default(IN_STOCK)
    unit         UnitType          @default(PIECE)
    deliveryType DeliveryType      @default(DELIVERY)
    isVerified   Boolean           @default(false)
    createdAt    DateTime          @default(now())
    orders       Order[]
    favoritedBy  FavoriteProduct[]
    categories   Category[]
}

model FavoriteService {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    serviceId String
    service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@unique([userId, serviceId]) // Prevent duplicate likes
}

model FavoriteProduct {
    id        String   @id @default(cuid())
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    productId String
    product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@unique([userId, productId]) // Prevent duplicate likes
}
