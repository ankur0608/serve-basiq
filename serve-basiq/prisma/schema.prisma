generator client {
    provider        = "prisma-client-js"
    engineType      = "library"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider = "postgresql"
}

enum PriceType {
    HOURLY
    FIXED
}

model Admin {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String // Will be hashed
    isOnline  Boolean  @default(false)
    lastLogin DateTime @default(now())
    createdAt DateTime @default(now())
}

model User {
    id       String  @id @default(cuid())
    name     String?
    shopName String?

    // ⚠️ CHANGE: Phone must be optional for Google Auth (users might not have one yet)
    phone String? @unique

    email         String?   @unique
    emailVerified DateTime? // ✅ Added: Standard NextAuth field
    image         String? // ✅ Added: Standard NextAuth profile image field

    role String  @default("USER")
    img  String? // Your existing custom image field (keep this if your UI uses it)

    isPhoneVerified Boolean @default(false)
    isWorker        Boolean @default(false)
    isWebsite       Boolean @default(true)
    rejectionReason String?

    // ✅ STATUS FLAGS
    isVerified         Boolean @default(false)
    verificationStatus String  @default("PENDING")

    // ✅ BANKING DETAILS
    bankAccountHolder String?
    bankAccountNumber String?
    bankIfsc          String?
    bankName          String?
    upiId             String?

    // ✅ KYC DOCUMENTS
    idProofType      String? @default("Aadhaar")
    idProofNumber    String?
    idProofImg       String?
    businessProofImg String?

    // ✅ RELATION: Link to the Account model for Google/NextAuth
    accounts Account[]

    // Relations
    services  Service[]
    addresses Address[]
    products  Product[]
    reviews   Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// ✅ NEW: Account Model (Required for NextAuth/Google)
model Account {
    id                String  @id @default(cuid())
    userId            String
    type              String
    provider          String
    providerAccountId String
    refresh_token     String? @db.Text
    access_token      String? @db.Text
    expires_at        Int?
    token_type        String?
    scope             String?
    id_token          String? @db.Text
    session_state     String?

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([provider, providerAccountId])
}

// --- ADDRESS MODEL (NEW) ---
model Address {
    id     String @id @default(cuid())
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    type    String @default("Home") // Home, Work, Other
    line1   String // Flat, Building, Street
    line2   String
    city    String
    state   String
    pincode String
    country String @default("India")

    createdAt DateTime @default(now())
}

// --- OTP MODEL ---
model Otp {
    id        String   @id @default(cuid())
    phone     String
    code      String
    expiresAt DateTime
    createdAt DateTime @default(now())
}

model Service {
    id Int @id @default(autoincrement())

    userId     String
    user       User      @relation(fields: [userId], references: [id])
    name       String
    desc       String
    img        String
    experience Int?
    altPhone   String?
    coverImg   String?
    mainimg    String?
    category   Category? @relation(fields: [categoryId], references: [id])
    categoryId String?

    subCategoryIds String[]
    priceType      PriceType @default(FIXED)
    price          Float     @default(0)

    addressLine1 String?
    addressLine2 String?
    city         String?
    state        String?
    pincode      String?

    latitude  Decimal?
    longitude Decimal?
    radiusKm  Int?     @default(10)

    workingDays String[]
    openTime    String?
    closeTime   String?

    // Details
    rating     Float    @default(5.0)
    loc        String?
    isVerified Boolean  @default(false)
    gallery    String[]

    reviews Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

// Example Helper Models
model Category {
    id       String    @id @default(uuid())
    name     String
    services Service[]
}

model Review {
    id      Int     @id @default(autoincrement())
    rating  Int
    comment String?

    // Link to the Service
    serviceId Int
    service   Service @relation(fields: [serviceId], references: [id])

    // Link to the User who wrote it
    authorId String
    author   User   @relation(fields: [authorId], references: [id])

    createdAt DateTime @default(now())
}

// --- PRODUCT MODEL ---
model Product {
    id Int @id @default(autoincrement())

    userId String // ✅ Link to Seller
    user   User   @relation(fields: [userId], references: [id])

    name    String
    cat     String
    img     String
    price   Float
    moq     String // Minimum Order Quantity (e.g., "10 Units")
    desc    String
    gallery String[]

    isVerified Boolean  @default(false)
    createdAt  DateTime @default(now())
}
